{
  "id": "surface-tablet-controls",
  "name": "Surface Tablet Controls",
  "version": "1.0.0",
  "minNoctaliaVersion": "4.4.3",
  "author": "PickleHik3",
  "license": "MIT",
  "repository": "https://github.com/PickleHik3/surface-noctalia",
  "description": "Bar controls for qs-hyprview recent apps and wvkbd actions on Hyprland tablets.",
  "tags": [
    "Bar",
    "Panel",
    "Utility",
    "System",
    "Hyprland"
  ],
  "entryPoints": {
    "main": "Main.qml",
    "barWidget": "BarWidget.qml",
    "panel": "Panel.qml",
    "settings": "Settings.qml"
  },
  "dependencies": {
    "plugins": []
  },
  "metadata": {
    "defaultSettings": {
      "recentAppsPath": "$HOME/.config/hypr/apps/qs-hyprview",
      "keyboardAutoScript": "$HOME/.config/hypr/apps/wvkbd/scripts/auto-show-wvkbd.sh",
      "keyboardShowScript": "$HOME/.config/hypr/apps/wvkbd/scripts/show-wvkbd.sh",
      "keyboardHideScript": "$HOME/.config/hypr/apps/wvkbd/scripts/hide-wvkbd.sh",
      "keyboardDisableScript": "$HOME/.config/hypr/apps/wvkbd/scripts/disable-wvkbd.sh"
    }
  }
}
